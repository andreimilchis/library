# Database (Supabase Transaction Pooler recommended for Vercel)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for migrations (use Supabase direct host)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Revolut Business API
# Get these from Revolut Business > Settings > APIs
REVOLUT_CLIENT_ID=""
# Private key in PKCS8 PEM format (generate with: openssl genrsa -out revolut_private.pem 2048)
# When setting in Vercel, replace newlines with \n
REVOLUT_PRIVATE_KEY=""
REVOLUT_API_URL="https://b2b.revolut.com/api/1.0"
REVOLUT_SANDBOX_URL="https://sandbox-b2b.revolut.com/api/1.0"
REVOLUT_USE_SANDBOX="false"
REVOLUT_REDIRECT_URI="https://your-app.vercel.app/api/revolut/oauth/callback"
REVOLUT_WEBHOOK_SECRET=""

# AI Agent (Claude API)
ANTHROPIC_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
