generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  DISCOVERY_SCHEDULED
  DISCOVERY_COMPLETED
  AUDIT_SENT
  OFFER_SENT
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  INBOUND
  OUTBOUND
  REFERRAL
  WEBSITE
  SOCIAL_MEDIA
  PAID_ADS
  EVENT
  OTHER
}

enum MeetingType {
  DISCOVERY
  FOLLOW_UP
  STRATEGY
  REVIEW
  ONBOARDING
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AuditStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELIVERED
}

enum OfferStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ClientStatus {
  ONBOARDING
  ACTIVE
  PAUSED
  CHURNED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum AdPlatform {
  META
  GOOGLE
  TIKTOK
  LINKEDIN
  PINTEREST
  SNAPCHAT
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ThreadChannel {
  EMAIL
  WHATSAPP
  SLACK
  INTERNAL
  SMS
  OTHER
}

enum ReportType {
  WEEKLY
  MONTHLY
  QUARTERLY
  AD_HOC
  CAMPAIGN
}

enum ReportStatus {
  DRAFT
  GENERATED
  DELIVERED
}

// ──────────────────────────────────────────────
// CORE ENTITIES
// ──────────────────────────────────────────────

model Lead {
  id           String     @id @default(uuid())
  companyName  String     @map("company_name")
  contactName  String     @map("contact_name")
  email        String
  phone        String?
  website      String?
  industry     String?
  source       LeadSource @default(OTHER)
  status       LeadStatus @default(NEW)
  notes        String?
  estimatedBudget Decimal?  @map("estimated_budget") @db.Decimal(12, 2)

  assignedToId String?    @map("assigned_to_id")
  assignedTo   AgencyUser? @relation(fields: [assignedToId], references: [id])

  // Lead → Client conversion
  client       Client?

  // Related entities
  discoveryMeetings DiscoveryMeeting[]
  audits            Audit[]
  offers            Offer[]
  communicationThreads CommunicationThread[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([source])
  @@index([assignedToId])
  @@index([email])
  @@map("leads")
}

model DiscoveryMeeting {
  id             String        @id @default(uuid())
  leadId         String        @map("lead_id")
  lead           Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  meetingType    MeetingType   @default(DISCOVERY) @map("meeting_type")
  status         MeetingStatus @default(SCHEDULED)
  scheduledAt    DateTime      @map("scheduled_at")
  durationMinutes Int?         @map("duration_minutes")

  recordingUrl   String?       @map("recording_url")
  transcript     String?
  summary        String?
  keyInsights    String?       @map("key_insights")

  conductedById  String?       @map("conducted_by_id")
  conductedBy    AgencyUser?   @relation(fields: [conductedById], references: [id])

  // A meeting can produce an audit and/or an offer
  audit          Audit?
  offer          Offer?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([leadId])
  @@index([scheduledAt])
  @@index([status])
  @@map("discovery_meetings")
}

model Audit {
  id              String      @id @default(uuid())
  leadId          String      @map("lead_id")
  lead            Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  meetingId       String?     @unique @map("meeting_id")
  meeting         DiscoveryMeeting? @relation(fields: [meetingId], references: [id])

  status          AuditStatus @default(PENDING)
  platform        AdPlatform?
  findings        String?
  recommendations String?
  score           Int?        // overall health score 0-100
  deliveredAt     DateTime?   @map("delivered_at")

  createdById     String?     @map("created_by_id")
  createdBy       AgencyUser? @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([leadId])
  @@index([status])
  @@map("audits")
}

model Offer {
  id              String      @id @default(uuid())
  leadId          String      @map("lead_id")
  lead            Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  meetingId       String?     @unique @map("meeting_id")
  meeting         DiscoveryMeeting? @relation(fields: [meetingId], references: [id])

  status          OfferStatus @default(DRAFT)
  title           String
  description     String?
  services        String?     // JSON array of service items
  monthlyFee      Decimal?    @map("monthly_fee") @db.Decimal(12, 2)
  setupFee        Decimal?    @map("setup_fee") @db.Decimal(12, 2)
  currency        String      @default("USD")
  validUntil      DateTime?   @map("valid_until")
  sentAt          DateTime?   @map("sent_at")
  respondedAt     DateTime?   @map("responded_at")

  createdById     String?     @map("created_by_id")
  createdBy       AgencyUser? @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([leadId])
  @@index([status])
  @@map("offers")
}

model Client {
  id             String       @id @default(uuid())
  leadId         String       @unique @map("lead_id")
  lead           Lead         @relation(fields: [leadId], references: [id])

  companyName    String       @map("company_name")
  contactName    String       @map("contact_name")
  email          String
  phone          String?
  website        String?
  industry       String?
  status         ClientStatus @default(ONBOARDING)

  monthlyBudget  Decimal?     @map("monthly_budget") @db.Decimal(12, 2)
  currency       String       @default("USD")
  onboardedAt    DateTime?    @map("onboarded_at")

  accountManagerId String?    @map("account_manager_id")
  accountManager   AgencyUser? @relation("ManagedClients", fields: [accountManagerId], references: [id])

  // Related entities
  contracts       Contract[]
  invoices        Invoice[]
  adAccounts      AdAccount[]
  tasks           Task[]
  reports         Report[]
  communicationThreads CommunicationThread[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([accountManagerId])
  @@index([email])
  @@map("clients")
}

model Contract {
  id              String         @id @default(uuid())
  clientId        String         @map("client_id")
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)

  status          ContractStatus @default(DRAFT)
  title           String
  description     String?
  startDate       DateTime?      @map("start_date")
  endDate         DateTime?      @map("end_date")
  monthlyFee      Decimal?       @map("monthly_fee") @db.Decimal(12, 2)
  currency        String         @default("USD")
  documentUrl     String?        @map("document_url")
  signedAt        DateTime?      @map("signed_at")
  externalId      String?        @map("external_id") // ID from contract signing tool

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([status])
  @@map("contracts")
}

model Invoice {
  id              String        @id @default(uuid())
  clientId        String        @map("client_id")
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  status          InvoiceStatus @default(DRAFT)
  invoiceNumber   String        @unique @map("invoice_number")
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("USD")
  description     String?
  issuedAt        DateTime?     @map("issued_at")
  dueAt           DateTime?     @map("due_at")
  paidAt          DateTime?     @map("paid_at")
  externalId      String?       @map("external_id") // ID from invoice system

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([status])
  @@index([dueAt])
  @@map("invoices")
}

model AdAccount {
  id              String     @id @default(uuid())
  clientId        String     @map("client_id")
  client          Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  platform        AdPlatform
  accountName     String     @map("account_name")
  externalAccountId String   @map("external_account_id") // Platform-specific account ID
  isActive        Boolean    @default(true) @map("is_active")
  currency        String     @default("USD")
  timezone        String     @default("UTC")

  // Related metrics
  campaignPerformance CampaignPerformance[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([platform, externalAccountId])
  @@index([clientId])
  @@index([platform])
  @@map("ad_accounts")
}

model CampaignPerformance {
  id              String    @id @default(uuid())
  adAccountId     String    @map("ad_account_id")
  adAccount       AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  date            DateTime  @db.Date
  campaignId      String    @map("campaign_id")     // External campaign ID
  campaignName    String    @map("campaign_name")

  // Core metrics
  spend           Decimal   @default(0) @db.Decimal(12, 2)
  revenue         Decimal   @default(0) @db.Decimal(12, 2)
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  conversions     Int       @default(0)

  // Computed / derived metrics stored for fast reads
  roas            Decimal?  @db.Decimal(8, 4)   // revenue / spend
  cpa             Decimal?  @db.Decimal(12, 2)  // spend / conversions
  ctr             Decimal?  @db.Decimal(8, 4)   // clicks / impressions
  cpc             Decimal?  @db.Decimal(12, 2)  // spend / clicks
  cpm             Decimal?  @db.Decimal(12, 2)  // (spend / impressions) * 1000

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([adAccountId, date, campaignId])
  @@index([adAccountId])
  @@index([date])
  @@index([campaignId])
  @@map("campaign_performance")
}

model Task {
  id            String       @id @default(uuid())
  clientId      String?      @map("client_id")
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  title         String
  description   String?
  status        TaskStatus   @default(TODO)
  priority      TaskPriority @default(MEDIUM)
  dueDate       DateTime?    @map("due_date")
  completedAt   DateTime?    @map("completed_at")

  assignedToId  String?      @map("assigned_to_id")
  assignedTo    AgencyUser?  @relation("AssignedTasks", fields: [assignedToId], references: [id])

  createdById   String?      @map("created_by_id")
  createdBy     AgencyUser?  @relation("CreatedTasks", fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([status])
  @@index([assignedToId])
  @@index([dueDate])
  @@map("tasks")
}

model CommunicationThread {
  id          String        @id @default(uuid())
  leadId      String?       @map("lead_id")
  lead        Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)

  clientId    String?       @map("client_id")
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)

  channel     ThreadChannel @default(INTERNAL)
  subject     String?
  isOpen      Boolean       @default(true) @map("is_open")

  messages    Message[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([leadId])
  @@index([clientId])
  @@index([channel])
  @@map("communication_threads")
}

model Message {
  id        String  @id @default(uuid())
  threadId  String  @map("thread_id")
  thread    CommunicationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  senderType String @map("sender_type") // "agency_user", "client", "system", "ai_agent"
  senderId   String? @map("sender_id")
  body       String
  metadata   String? // JSON for attachments, external message IDs, etc.

  createdAt DateTime @default(now()) @map("created_at")

  @@index([threadId])
  @@index([createdAt])
  @@map("messages")
}

model Report {
  id          String       @id @default(uuid())
  clientId    String       @map("client_id")
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type        ReportType   @default(MONTHLY)
  status      ReportStatus @default(DRAFT)
  title       String
  periodStart DateTime     @map("period_start")
  periodEnd   DateTime     @map("period_end")
  content     String?      // Report body / markdown / JSON
  summary     String?
  deliveredAt DateTime?    @map("delivered_at")

  generatedById String?    @map("generated_by_id")
  generatedBy   AgencyUser? @relation(fields: [generatedById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([type])
  @@index([periodStart, periodEnd])
  @@map("reports")
}

// ──────────────────────────────────────────────
// AGENCY INTERNAL
// ──────────────────────────────────────────────

model AgencyUser {
  id        String  @id @default(uuid())
  email     String  @unique
  name      String
  role      String  @default("member") // admin, manager, member
  isActive  Boolean @default(true) @map("is_active")

  // Relations
  assignedLeads    Lead[]
  conductedMeetings DiscoveryMeeting[]
  createdAudits    Audit[]
  createdOffers    Offer[]
  managedClients   Client[] @relation("ManagedClients")
  assignedTasks    Task[]   @relation("AssignedTasks")
  createdTasks     Task[]   @relation("CreatedTasks")
  generatedReports Report[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("agency_users")
}
