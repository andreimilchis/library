# Database
DATABASE_URL="postgresql://user:password@localhost:5432/contract_signer"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3001"

# App URL (used for signing links in emails)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Email (Resend - get your key at https://resend.com)
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="NETkyu Contract Signer <office@netkyu.com>"

# Admin seed (optional - used by npm run db:seed)
# ADMIN_EMAIL="admin@netkyu.com"
# ADMIN_PASSWORD="change-this-password"
# ADMIN_NAME="NETkyu Admin"
