// EcommSuite.AI Database Schema
// This file defines the structure of your database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  plan          Plan      @default(STARTER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  stores        Store[]
  campaigns     Campaign[]
  emailLists    EmailList[]
  creatives     Creative[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Plan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

// ============================================
// SHOPIFY STORE CONNECTION
// ============================================

model Store {
  id              String   @id @default(cuid())
  userId          String
  shopifyDomain   String   @unique
  shopifyToken    String
  shopName        String?
  shopEmail       String?
  currency        String   @default("USD")
  timezone        String   @default("America/New_York")
  isActive        Boolean  @default(true)
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products        Product[]
  customers       Customer[]
  orders          Order[]
  campaigns       Campaign[]

  @@map("stores")
}

model Product {
  id              String   @id @default(cuid())
  storeId         String
  shopifyId       String
  title           String
  description     String?  @db.Text
  handle          String?
  vendor          String?
  productType     String?
  tags            String[]
  imageUrl        String?
  images          String[]
  price           Decimal  @db.Decimal(10, 2)
  compareAtPrice  Decimal? @db.Decimal(10, 2)
  inventory       Int      @default(0)
  status          ProductStatus @default(ACTIVE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, shopifyId])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

model Customer {
  id              String   @id @default(cuid())
  storeId         String
  shopifyId       String
  email           String
  firstName       String?
  lastName        String?
  phone           String?
  totalSpent      Decimal  @default(0) @db.Decimal(10, 2)
  ordersCount     Int      @default(0)
  tags            String[]
  acceptsMarketing Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders          Order[]

  @@unique([storeId, shopifyId])
  @@map("customers")
}

model Order {
  id              String   @id @default(cuid())
  storeId         String
  customerId      String?
  shopifyId       String
  orderNumber     String
  totalPrice      Decimal  @db.Decimal(10, 2)
  subtotalPrice   Decimal  @db.Decimal(10, 2)
  totalTax        Decimal  @default(0) @db.Decimal(10, 2)
  currency        String   @default("USD")
  financialStatus String?
  fulfillmentStatus String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([storeId, shopifyId])
  @@map("orders")
}

// ============================================
// AD CAMPAIGNS
// ============================================

model Campaign {
  id              String   @id @default(cuid())
  userId          String
  storeId         String?
  name            String
  platform        AdPlatform
  status          CampaignStatus @default(DRAFT)
  objective       String?
  budget          Decimal  @db.Decimal(10, 2)
  budgetType      BudgetType @default(DAILY)
  startDate       DateTime?
  endDate         DateTime?
  externalId      String?  // ID from Meta/Google/TikTok

  // Performance metrics (synced from platform)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  spend           Decimal  @default(0) @db.Decimal(10, 2)
  conversions     Int      @default(0)
  revenue         Decimal  @default(0) @db.Decimal(10, 2)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store           Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  adSets          AdSet[]

  @@map("campaigns")
}

model AdSet {
  id              String   @id @default(cuid())
  campaignId      String
  name            String
  status          CampaignStatus @default(DRAFT)
  targeting       Json?    // Audience targeting config
  budget          Decimal? @db.Decimal(10, 2)
  externalId      String?

  // Performance
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  spend           Decimal  @default(0) @db.Decimal(10, 2)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads             Ad[]

  @@map("ad_sets")
}

model Ad {
  id              String   @id @default(cuid())
  adSetId         String
  name            String
  status          CampaignStatus @default(DRAFT)
  headline        String?
  description     String?  @db.Text
  callToAction    String?
  imageUrl        String?
  videoUrl        String?
  destinationUrl  String?
  externalId      String?

  // Performance
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  spend           Decimal  @default(0) @db.Decimal(10, 2)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  adSet           AdSet    @relation(fields: [adSetId], references: [id], onDelete: Cascade)

  @@map("ads")
}

enum AdPlatform {
  META
  GOOGLE
  TIKTOK
}

enum CampaignStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum BudgetType {
  DAILY
  LIFETIME
}

// ============================================
// EMAIL MARKETING
// ============================================

model EmailList {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  subscriberCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscribers     EmailSubscriber[]
  emailCampaigns  EmailCampaign[]

  @@map("email_lists")
}

model EmailSubscriber {
  id              String   @id @default(cuid())
  listId          String
  email           String
  firstName       String?
  lastName        String?
  status          SubscriberStatus @default(ACTIVE)
  source          String?  // Where they signed up
  customFields    Json?
  subscribedAt    DateTime @default(now())
  unsubscribedAt  DateTime?

  // Relations
  list            EmailList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, email])
  @@map("email_subscribers")
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

model EmailCampaign {
  id              String   @id @default(cuid())
  listId          String
  name            String
  subject         String
  previewText     String?
  htmlContent     String   @db.Text
  textContent     String?  @db.Text
  status          EmailCampaignStatus @default(DRAFT)
  scheduledAt     DateTime?
  sentAt          DateTime?

  // Metrics
  sent            Int      @default(0)
  delivered       Int      @default(0)
  opened          Int      @default(0)
  clicked         Int      @default(0)
  bounced         Int      @default(0)
  unsubscribed    Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  list            EmailList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@map("email_campaigns")
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

model EmailAutomation {
  id              String   @id @default(cuid())
  userId          String
  name            String
  trigger         AutomationTrigger
  status          AutomationStatus @default(INACTIVE)
  delayMinutes    Int      @default(0)
  subject         String
  htmlContent     String   @db.Text

  // Stats
  sent            Int      @default(0)
  opened          Int      @default(0)
  clicked         Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("email_automations")
}

enum AutomationTrigger {
  WELCOME
  ABANDONED_CART
  POST_PURCHASE
  WIN_BACK
  BIRTHDAY
  PRODUCT_LAUNCH
}

enum AutomationStatus {
  ACTIVE
  INACTIVE
  PAUSED
}

// ============================================
// CREATIVE STUDIO
// ============================================

model Creative {
  id              String   @id @default(cuid())
  userId          String
  name            String
  type            CreativeType
  width           Int
  height          Int
  fileUrl         String?
  thumbnailUrl    String?
  designData      Json?    // Canvas/editor state
  status          CreativeStatus @default(DRAFT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("creatives")
}

enum CreativeType {
  BANNER
  VIDEO
  SOCIAL_POST
  EMAIL_HEADER
}

enum CreativeStatus {
  DRAFT
  COMPLETED
  ARCHIVED
}

// ============================================
// PLATFORM CONNECTIONS
// ============================================

model PlatformConnection {
  id              String   @id @default(cuid())
  userId          String
  platform        Platform
  accessToken     String   @db.Text
  refreshToken    String?  @db.Text
  expiresAt       DateTime?
  accountId       String?
  accountName     String?
  isActive        Boolean  @default(true)
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, platform])
  @@map("platform_connections")
}

enum Platform {
  SHOPIFY
  META
  GOOGLE
  TIKTOK
  SENDGRID
}

// ============================================
// ANALYTICS & REPORTING
// ============================================

model DailyMetrics {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date

  // Revenue
  totalRevenue    Decimal  @default(0) @db.Decimal(12, 2)
  ordersCount     Int      @default(0)
  avgOrderValue   Decimal  @default(0) @db.Decimal(10, 2)

  // Ads
  adSpend         Decimal  @default(0) @db.Decimal(10, 2)
  adImpressions   Int      @default(0)
  adClicks        Int      @default(0)
  adConversions   Int      @default(0)
  roas            Decimal  @default(0) @db.Decimal(5, 2)

  // Email
  emailsSent      Int      @default(0)
  emailsOpened    Int      @default(0)
  emailsClicked   Int      @default(0)

  // Traffic
  visitors        Int      @default(0)
  newCustomers    Int      @default(0)

  createdAt       DateTime @default(now())

  @@unique([userId, date])
  @@map("daily_metrics")
}
