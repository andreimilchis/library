# ============================================
# ECOMMSUITE.AI - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/ecommsuite"

# ============================================
# AUTHENTICATION (NextAuth.js)
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-here-change-in-production"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================
# SHOPIFY INTEGRATION
# ============================================
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SCOPES="read_products,read_orders,read_customers,read_inventory"

# ============================================
# META (FACEBOOK) INTEGRATION
# ============================================
META_APP_ID=""
META_APP_SECRET=""
META_API_VERSION="v18.0"

# ============================================
# GOOGLE ADS INTEGRATION
# ============================================
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_DEVELOPER_TOKEN=""

# ============================================
# TIKTOK INTEGRATION
# ============================================
TIKTOK_APP_ID=""
TIKTOK_APP_SECRET=""

# ============================================
# EMAIL SERVICE (SendGrid)
# ============================================
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@ecommsuite.ai"
SENDGRID_FROM_NAME="EcommSuite.AI"

# ============================================
# AI SERVICES
# ============================================
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4"

# ============================================
# FILE STORAGE (AWS S3)
# ============================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_URL=""

# ============================================
# REDIS (for queues and caching)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# STRIPE (for payments)
# ============================================
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs
STRIPE_STARTER_PRICE_ID=""
STRIPE_GROWTH_PRICE_ID=""
STRIPE_SCALE_PRICE_ID=""

# ============================================
# APPLICATION
# ============================================
NODE_ENV="development"
APP_URL="http://localhost:3000"

# ============================================
# ANALYTICS (optional)
# ============================================
GOOGLE_ANALYTICS_ID=""
MIXPANEL_TOKEN=""
